<Window x:Class="UniversityScheduler.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:UniversityScheduler.UI"
        xmlns:vm="clr-namespace:UniversityScheduler.UI.ViewModels"
        xmlns:conv="clr-namespace:UniversityScheduler.UI"
        mc:Ignorable="d"
        Title="Планировщик расписания университета" Height="700" Width="1100">
    
    <Window.Resources>
        <conv:TimeSlotConverter x:Key="TimeSlotConverter"/>
    </Window.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0">
            <TabItem Header="Расписание">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Orientation="Horizontal" Margin="5">
                        <Button Content="Создать расписание" Padding="10,5" Margin="5" Command="{Binding GenerateScheduleCommand}"/>
                        <Button Content="Оптимизировать" Padding="10,5" Margin="5" Command="{Binding OptimizeScheduleCommand}"/>
                        <Button Content="Проверить конфликты" Padding="10,5" Margin="5" Command="{Binding CheckConflictsCommand}"/>
                    </StackPanel>

                    <DataGrid Grid.Row="1" ItemsSource="{Binding Sessions}" AutoGenerateColumns="False" Margin="5" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="40" />
                            <DataGridTextColumn Header="Предмет" Binding="{Binding Subject}" Width="150" />
                            <DataGridTextColumn Header="Группа" Binding="{Binding Group.Name}" Width="80" />
                            <DataGridTextColumn Header="Преподаватель" Binding="{Binding Lector.Name}" Width="150" />
                            <DataGridTextColumn Header="Тип аудитории" Binding="{Binding RequiredType}" Width="100" />
                            <DataGridTextColumn Header="Длительность" Binding="{Binding Duration}" Width="80" />
                            <DataGridTextColumn Header="Аудитория" Binding="{Binding Room.Number}" Width="80" />
                            <DataGridTextColumn Header="Время" Width="120">
                                <DataGridTextColumn.Binding>
                                    <MultiBinding Converter="{StaticResource TimeSlotConverter}">
                                        <Binding Path="TimeSlot"/>
                                        <Binding Path="Duration"/>
                                    </MultiBinding>
                                </DataGridTextColumn.Binding>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
            
            <TabItem Header="По группам">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0" Margin="5">
                        <TextBlock Text="Выберите группу:" Margin="0,5"/>
                        <ListBox ItemsSource="{Binding Groups}" SelectedItem="{Binding SelectedGroup}" DisplayMemberPath="Name" Height="300"/>
                    </StackPanel>
                    
                    <DataGrid Grid.Column="1" ItemsSource="{Binding FilteredSessions}" AutoGenerateColumns="False" Margin="5" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="День и время" Width="150">
                                <DataGridTextColumn.Binding>
                                    <MultiBinding Converter="{StaticResource TimeSlotConverter}">
                                        <Binding Path="TimeSlot"/>
                                        <Binding Path="Duration"/>
                                    </MultiBinding>
                                </DataGridTextColumn.Binding>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Предмет" Binding="{Binding Subject}" Width="200" />
                            <DataGridTextColumn Header="Преподаватель" Binding="{Binding Lector.Name}" Width="150" />
                            <DataGridTextColumn Header="Аудитория" Binding="{Binding Room.Number}" Width="80" />
                            <DataGridTextColumn Header="Длительность" Binding="{Binding Duration}" Width="80" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
            
            <TabItem Header="По преподавателям">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0" Margin="5">
                        <TextBlock Text="Выберите преподавателя:" Margin="0,5"/>
                        <ListBox ItemsSource="{Binding Lectors}" SelectedItem="{Binding SelectedLector}" DisplayMemberPath="Name" Height="300"/>
                    </StackPanel>
                    
                    <DataGrid Grid.Column="1" ItemsSource="{Binding FilteredSessions}" AutoGenerateColumns="False" Margin="5" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="День и время" Width="150">
                                <DataGridTextColumn.Binding>
                                    <MultiBinding Converter="{StaticResource TimeSlotConverter}">
                                        <Binding Path="TimeSlot"/>
                                        <Binding Path="Duration"/>
                                    </MultiBinding>
                                </DataGridTextColumn.Binding>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Предмет" Binding="{Binding Subject}" Width="200" />
                            <DataGridTextColumn Header="Группа" Binding="{Binding Group.Name}" Width="80" />
                            <DataGridTextColumn Header="Аудитория" Binding="{Binding Room.Number}" Width="80" />
                            <DataGridTextColumn Header="Длительность" Binding="{Binding Duration}" Width="80" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
            
            <TabItem Header="По предметам">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0" Margin="5">
                        <TextBlock Text="Выберите предмет:" Margin="0,5"/>
                        <ListBox ItemsSource="{Binding Subjects}" SelectedItem="{Binding SelectedSubject}" Height="300"/>
                    </StackPanel>
                    
                    <DataGrid Grid.Column="1" ItemsSource="{Binding FilteredSessions}" AutoGenerateColumns="False" Margin="5" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="День и время" Width="150">
                                <DataGridTextColumn.Binding>
                                    <MultiBinding Converter="{StaticResource TimeSlotConverter}">
                                        <Binding Path="TimeSlot"/>
                                        <Binding Path="Duration"/>
                                    </MultiBinding>
                                </DataGridTextColumn.Binding>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Группа" Binding="{Binding Group.Name}" Width="80" />
                            <DataGridTextColumn Header="Преподаватель" Binding="{Binding Lector.Name}" Width="150" />
                            <DataGridTextColumn Header="Аудитория" Binding="{Binding Room.Number}" Width="80" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
            
            <TabItem Header="Данные">
                <UniformGrid Columns="2">
                    <GroupBox Header="Группы" Margin="5">
                        <ListBox ItemsSource="{Binding Groups}" DisplayMemberPath="Name"/>
                    </GroupBox>
                    <GroupBox Header="Преподаватели" Margin="5">
                        <ListBox ItemsSource="{Binding Lectors}" DisplayMemberPath="Name"/>
                    </GroupBox>
                    <GroupBox Header="Аудитории" Margin="5">
                        <ListBox ItemsSource="{Binding Rooms}" DisplayMemberPath="Number"/>
                    </GroupBox>
                    <GroupBox Header="Занятия" Margin="5">
                        <ListBox ItemsSource="{Binding Sessions}" DisplayMemberPath="Subject"/>
                    </GroupBox>
                </UniformGrid>
            </TabItem>

            <TabItem Header="Статистика">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="250"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Статистика" FontSize="24" FontWeight="Bold" Margin="0,10"/>
                    
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Загрузка аудиторий:" FontSize="16" Margin="0,10"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding RoomUtilization}" FontSize="16" Margin="0,10"/>
                    
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Нагрузка преподавателей:" FontSize="16" Margin="0,10"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding LectorWorkload}" FontSize="16" Margin="0,10"/>
                    
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Окон:" FontSize="16" Margin="0,10"/>
                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding GapsCount}" FontSize="16" Margin="0,10"/>
                    
                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Время генерации:" FontSize="16" Margin="0,10"/>
                    <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding GenerateTime}" FontSize="16" Margin="0,10"/>
                    
                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Время оптимизации:" FontSize="16" Margin="0,10"/>
                    <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding OptimizeTime}" FontSize="16" Margin="0,10"/>
                </Grid>
            </TabItem>
        </TabControl>

        <StatusBar Grid.Row="1">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}" />
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
